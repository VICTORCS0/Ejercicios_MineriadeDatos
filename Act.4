dividendo = int(input("Ingresa el dividendo: "))
divisor = int(input("Ingresa el divisor: "))

c = dividendo // divisor
r = dividendo % divisor

print("Resultado:")
print(dividendo, "entre", divisor, "da un cociente", c, "y un residuo", r)
print("Donde", dividendo, "y", divisor, "son los números introducidos por el usuario,")
print("y", c, "y", r, "son el cociente y el residuo de la división entera respectivamente.")
